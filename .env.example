NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEON_BRANCH=main
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Trigger.dev — get from the dashboard API Keys page (DEV key starts with tr_dev_)
TRIGGER_SECRET_KEY=

NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=
LIVEBLOCKS_SECRET_KEY=

# Browserbase — Cloud browser sessions for Stagehand browser automation
BROWSERBASE_API_KEY=

# Resend — Transactional email (quotes, invoices, finance forms)
RESEND_API_KEY=

# Sent.dm — Unified messaging API for WhatsApp, SMS, RCS
# Get your API key from https://app.sent.dm
SENT_DM_API_KEY=
SENT_DM_WEBHOOK_SECRET=

# LLM API — For blog writing, financial info parsing, and AI features
# Can be any OpenAI-compatible endpoint
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# Telegram Bot — For processing finance applications via Telegram
# Get token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Discord Bot — For processing finance applications via Discord
# Get from https://discord.com/developers/applications
DISCORD_APP_ID=
DISCORD_BOT_TOKEN=

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Build-time secret for source map upload (starts with sntrys_)
SENTRY_AUTH_TOKEN=
